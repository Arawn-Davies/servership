<% @title = 'Sign in' %>
<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-sm rounded-2xl border border-slate-800 bg-slate-900/60 p-7">
    <div class="text-center mb-6">
      <div class="text-3xl">⚓</div>
      <h1 class="text-lg font-semibold mt-1">Servership</h1>
      <p class="text-sm text-slate-500">Sign in to your fleet</p>
    </div>

    <% if @error %>
      <div class="mb-4 rounded-lg bg-rose-500/10 border border-rose-500/30 text-rose-300 text-sm px-3 py-2"><%= @error %></div>
    <% end %>

    <% if github_enabled? %>
      <form method="post" action="/auth/github">
        <input type="hidden" name="authenticity_token" value="<%= Rack::Protection::AuthenticityToken.token(session) %>">
        <button class="w-full rounded-lg bg-slate-100 text-slate-900 font-medium py-2.5 hover:bg-white transition">
          Sign in with GitHub
        </button>
      </form>
      <% if local_enabled? %>
        <div class="flex items-center gap-3 my-5 text-xs text-slate-600">
          <div class="h-px flex-1 bg-slate-800"></div>or<div class="h-px flex-1 bg-slate-800"></div>
        </div>
      <% end %>
    <% end %>

    <% if local_enabled? %>
      <form method="post" action="/login" class="space-y-3">
        <input name="user" placeholder="Username" autofocus autocomplete="username"
          class="w-full rounded-lg bg-slate-950 border border-slate-800 px-3 py-2 text-sm focus:border-sky-500 outline-none">
        <input name="pass" type="password" placeholder="Password" autocomplete="current-password"
          class="w-full rounded-lg bg-slate-950 border border-slate-800 px-3 py-2 text-sm focus:border-sky-500 outline-none">
        <button class="w-full rounded-lg border border-slate-700 py-2.5 text-sm hover:border-sky-500 hover:bg-sky-500/10 transition">
          Sign in
        </button>
      </form>
    <% end %>

    <% unless auth_enabled? %>
      <p class="text-sm text-slate-500 text-center">No auth configured. Set <code>GITHUB_*</code> or <code>PLATFORM_*</code> in <code>.env</code>.</p>
    <% end %>
  </div>
</div>
