<% @title = "#{@node[:label]} console" %>
<div class="flex items-start gap-3 mb-4">
  <% iface, rest = @node[:kind].to_s.split(' · ', 2) %>
  <div>
    <h1 class="text-2xl font-bold tracking-tight"><%= @node[:label] %></h1>
    <div class="text-sm text-slate-500 mt-0.5"><%= iface %> <span class="text-slate-600">console</span><%= rest ? " · #{rest}" : '' %></div>
  </div>
  <a href="/dashboard" class="ml-auto text-sm text-slate-400 hover:text-slate-200">← dashboard</a>
</div>
<p class="text-sm text-slate-400 mb-3">
  <% if @ckey == 'ilo' %>
    Log in, then open the <b>Remote Console</b> tab.
  <% else %>
    Log in, then <b>Console/Media → Launch Virtual Console</b> (Java plug-in).
  <% end %>
</p>
<iframe id="vnc"
  src="/novnc/vnc.html?path=websockify/<%= @ckey %>&autoconnect=true&resize=remote&reconnect=true"
  class="w-full rounded-2xl border border-slate-800 bg-black"
  style="height:82vh"></iframe>

<div class="flex gap-2 mt-3">
  <button onclick="consoleAction('reload')"
    class="px-4 py-2 rounded-lg text-sm border border-slate-700 hover:border-sky-500 hover:bg-sky-500/10 text-slate-200">Reload</button>
  <button onclick="consoleAction('exit')"
    class="px-4 py-2 rounded-lg text-sm border border-slate-700 hover:border-rose-500 hover:bg-rose-500/10 text-slate-200">Exit</button>
  <span id="cstatus" class="self-center text-sm text-slate-500"></span>
</div>

<script>
function consoleAction(action){
  var s = document.getElementById('cstatus');
  var f = document.getElementById('vnc');
  if (action === 'exit') {
    // instant: drop the noVNC connection + blank the frame, fire the kill in the
    // background, and go straight to the fast landing page (dashboard is slow -
    // it queries IPMI on load).
    s.textContent = 'stopping console...';
    f.src = 'about:blank';
    fetch('/console/<%= @ckey %>/exit', { method: 'POST' });
    setTimeout(function(){ window.location = '/'; }, 250);
    return;
  }
  // reload: relaunch Firefox on the engine, then reconnect noVNC
  s.textContent = 'reloading console...';
  fetch('/console/<%= @ckey %>/reload', { method: 'POST' })
    .then(function(){
      setTimeout(function(){ f.src = f.src; s.textContent = ''; }, 2000);
    })
    .catch(function(){ s.textContent = 'failed'; });
}
</script>
