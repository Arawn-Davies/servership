<% @title = 'Dashboard'; @refresh = 20 %>
<div class="flex items-center justify-between mb-6 gap-4 flex-wrap">
  <h1 class="text-2xl font-semibold tracking-tight">Dashboard</h1>
  <div class="flex items-center gap-3">
    <div class="flex items-center gap-1 text-xs">
      <span class="text-slate-500 mr-1">Fans</span>
      <button data-unit="native"  class="fanunit px-2 py-1 rounded border border-slate-700 text-slate-300">Native</button>
      <button data-unit="percent" class="fanunit px-2 py-1 rounded border border-slate-700 text-slate-300">%</button>
      <button data-unit="rpm"     class="fanunit px-2 py-1 rounded border border-slate-700 text-slate-300">RPM</button>
    </div>
    <button onclick="openForm(true)"
      class="px-3 py-1.5 rounded-lg text-sm border border-emerald-600 text-emerald-300 hover:bg-emerald-500/10">+ Add server</button>
  </div>
</div>

<form id="srvform" method="post" action="/servers"
      class="hidden mb-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
  <input type="hidden" name="id" id="f_id">
  <div class="text-sm font-medium mb-3" id="f_title">Add server</div>
  <div class="grid sm:grid-cols-3 gap-3">
    <label class="text-xs text-slate-400 block">Label
      <input name="label" id="f_label" required
        class="mt-1 w-full rounded-lg bg-slate-950 border border-slate-800 px-3 py-2 text-sm text-slate-100"></label>
    <label class="text-xs text-slate-400 block">BMC IP
      <input name="ip" id="f_ip" required
        class="mt-1 w-full rounded-lg bg-slate-950 border border-slate-800 px-3 py-2 text-sm text-slate-100"></label>
    <label class="text-xs text-slate-400 block">Vendor
      <select name="vendor" id="f_vendor"
        class="mt-1 w-full rounded-lg bg-slate-950 border border-slate-800 px-3 py-2 text-sm text-slate-100">
        <option value="hp">HP (fans %)</option>
        <option value="dell">Dell (fans RPM)</option>
        <option value="other">Other</option>
      </select></label>
    <label class="text-xs text-slate-400 block">Username
      <input name="user" id="f_user" autocomplete="off"
        class="mt-1 w-full rounded-lg bg-slate-950 border border-slate-800 px-3 py-2 text-sm text-slate-100"></label>
    <label class="text-xs text-slate-400 block">Password <span id="f_passhint" class="text-slate-600"></span>
      <input name="pass" id="f_pass" type="password" autocomplete="new-password"
        class="mt-1 w-full rounded-lg bg-slate-950 border border-slate-800 px-3 py-2 text-sm text-slate-100"></label>
    <label class="text-xs text-slate-400 block">Fan max RPM
      <input name="fan_max" id="f_fanmax" value="12000"
        class="mt-1 w-full rounded-lg bg-slate-950 border border-slate-800 px-3 py-2 text-sm text-slate-100"></label>
  </div>
  <div class="flex gap-2 mt-4">
    <button class="px-4 py-2 rounded-lg text-sm bg-emerald-600 text-white hover:bg-emerald-500">Save</button>
    <button type="button" onclick="closeForm()"
      class="px-4 py-2 rounded-lg text-sm border border-slate-700 text-slate-300">Cancel</button>
  </div>
</form>

<% if @servers.empty? %>
  <div class="text-slate-500 text-sm">No servers yet. Click <b>+ Add server</b> to add a BMC.</div>
<% end %>

<% @servers.each do |n| %>
  <% s = @nodes[n[:id]] || {} %>
  <% sc = status_class(s[:power], s[:ok]) %>
  <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6 mb-6">
    <div class="flex items-center gap-3 flex-wrap">
      <h2 class="text-lg font-semibold"><%= n[:label] %></h2>
      <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold
        <%= sc == 'on' ? 'bg-emerald-500/15 text-emerald-400' :
             sc == 'off' ? 'bg-rose-500/15 text-rose-400' : 'bg-slate-500/15 text-slate-400' %>">
        <%= s[:power] || 'unknown' %>
      </span>
      <span class="text-sm text-slate-500"><%= n[:kind] %> · <%= n[:ip].to_s.empty? ? 'no ip' : n[:ip] %></span>
      <div class="ml-auto flex items-center gap-3 text-sm">
        <% if n[:console] %>
          <a href="/console/<%= n[:console] %>" class="text-<%= n[:accent] %>-400 hover:underline">Open console →</a>
        <% end %>
        <button class="edit-btn text-slate-400 hover:text-slate-200"
          data-id="<%= n[:id] %>" data-label="<%= n[:label] %>" data-ip="<%= n[:ip] %>"
          data-user="<%= n[:user] %>" data-vendor="<%= n[:vendor] %>" data-fanmax="<%= n[:fan_max] %>">Edit</button>
        <form method="post" action="/servers/<%= n[:id] %>/delete" class="inline"
          onsubmit="return confirm('Delete <%= n[:label] %>?')">
          <button class="text-rose-400 hover:text-rose-300">Delete</button>
        </form>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-5">
      <% [['Power draw', s[:watts] || '-'], ['Ambient', ambient(s[:temps] || [])],
          ['Fans OK', fans_ok(s[:fans] || [])], ['Sensors', (s[:temps]||[]).size + (s[:volts]||[]).size]].each do |kk, vv| %>
        <div class="rounded-xl bg-slate-950/60 border border-slate-800 p-3">
          <div class="text-[11px] uppercase tracking-wide text-slate-500"><%= kk %></div>
          <div class="text-xl font-semibold mt-0.5"><%= vv %></div>
        </div>
      <% end %>
    </div>

    <div class="grid md:grid-cols-2 gap-5 mt-5">
      <% [['Temperatures', s[:temps], false], ['Fans', s[:fans], true]].each do |title, rows, isfan| %>
        <div>
          <div class="text-sm font-medium mb-2"><%= title %></div>
          <div class="max-h-48 overflow-auto rounded-xl border border-slate-800">
            <table class="w-full text-xs">
              <% (rows || []).each do |a, b, c| %>
                <tr class="border-b border-slate-800/60">
                  <td class="px-3 py-1.5 text-slate-300"><%= a %></td>
                  <% if isfan %>
                    <% fv, fu = fan_bits(b) %>
                    <td class="px-3 py-1.5 text-slate-400 fanval"
                        data-orig="<%= b %>" data-val="<%= fv %>" data-unit="<%= fu %>" data-max="<%= n[:fan_max] %>"><%= b %></td>
                  <% else %>
                    <td class="px-3 py-1.5 text-slate-400"><%= b %></td>
                  <% end %>
                  <td class="px-3 py-1.5 <%= c.to_s.downcase.include?('ok') ? 'text-emerald-400' : 'text-slate-500' %>"><%= c %></td>
                </tr>
              <% end %>
              <% if (rows || []).empty? %><tr><td class="px-3 py-2 text-slate-600">none</td></tr><% end %>
            </table>
          </div>
        </div>
      <% end %>
    </div>

    <% if !(s[:sel] || []).empty? %>
      <details class="mt-4"><summary class="text-sm text-slate-500 cursor-pointer">Recent SEL events (<%= s[:sel].size %>)</summary>
        <pre class="mt-2 text-[11px] text-slate-400 bg-slate-950/60 rounded-xl border border-slate-800 p-3 overflow-auto"><%= s[:sel].join("\n") %></pre>
      </details>
    <% end %>

    <div class="flex flex-wrap gap-2 mt-5">
      <% [['on','Power On','emerald'], ['soft','Soft Shutdown','slate'], ['cycle','Power Cycle','amber'],
          ['reset','Reset','amber'], ['off','Force Off','rose'], ['identify','Identify LED','indigo'],
          ['selclear','Clear SEL','slate']].each do |act, lbl, col| %>
        <button onclick="act('<%= n[:id] %>','<%= act %>')"
          class="px-3 py-1.5 rounded-lg text-sm border border-slate-700 hover:border-<%= col %>-500 hover:bg-<%= col %>-500/10 text-slate-200"><%= lbl %></button>
      <% end %>
    </div>
  </section>
<% end %>

<script>
function act(node, action){
  if(['off','cycle','reset','selclear'].includes(action) &&
     !confirm(node + ': ' + action + ' - are you sure?')) return;
  fetch('/power', {method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({node:node, action:action})})
    .then(r => r.text()).then(t => { alert(t); location.reload(); })
    .catch(e => alert('failed: ' + e));
}

// add/edit server form
function openForm(reset){
  var f = document.getElementById('srvform');
  if (reset){
    f.reset();
    document.getElementById('f_id').value = '';
    document.getElementById('f_title').textContent = 'Add server';
    document.getElementById('f_passhint').textContent = '';
    document.getElementById('f_fanmax').value = '12000';
  }
  f.classList.remove('hidden');
  document.getElementById('f_label').focus();
}
function closeForm(){ document.getElementById('srvform').classList.add('hidden'); }
document.addEventListener('DOMContentLoaded', function(){
  document.querySelectorAll('.edit-btn').forEach(function(b){
    b.addEventListener('click', function(){
      document.getElementById('f_id').value     = b.dataset.id;
      document.getElementById('f_label').value  = b.dataset.label;
      document.getElementById('f_ip').value     = b.dataset.ip;
      document.getElementById('f_user').value   = b.dataset.user;
      document.getElementById('f_vendor').value = b.dataset.vendor || 'other';
      document.getElementById('f_fanmax').value = b.dataset.fanmax;
      document.getElementById('f_pass').value   = '';
      document.getElementById('f_passhint').textContent = '(leave blank to keep)';
      document.getElementById('f_title').textContent = 'Edit ' + b.dataset.label;
      openForm(false);
      window.scrollTo(0, 0);
    });
  });
});

// fan unit toggle (HP % <-> Dell RPM), converted values prefixed ~
function renderFans(unit){
  document.querySelectorAll('.fanunit').forEach(function(b){
    var on = b.dataset.unit === unit;
    b.classList.toggle('bg-sky-500/15', on);
    b.classList.toggle('border-sky-500', on);
    b.classList.toggle('text-sky-300', on);
  });
  document.querySelectorAll('.fanval').forEach(function(td){
    var v = parseFloat(td.dataset.val), u = td.dataset.unit, max = parseFloat(td.dataset.max);
    if (unit === 'native' || isNaN(v) || !u){ td.textContent = td.dataset.orig; return; }
    if (unit === 'percent'){
      var pct = (u === 'percent') ? v : (max ? v / max * 100 : NaN);
      td.textContent = isNaN(pct) ? td.dataset.orig : (u === 'percent' ? '' : '~') + (Math.round(pct * 10) / 10) + '%';
    } else {
      var rpm = (u === 'rpm') ? v : Math.round(v / 100 * max);
      td.textContent = (u === 'rpm' ? '' : '~') + rpm + ' RPM';
    }
  });
}
function setFanUnit(unit){ localStorage.setItem('fanUnit', unit); renderFans(unit); }
document.addEventListener('DOMContentLoaded', function(){
  document.querySelectorAll('.fanunit').forEach(function(b){
    b.addEventListener('click', function(){ setFanUnit(b.dataset.unit); });
  });
  renderFans(localStorage.getItem('fanUnit') || 'native');
});
</script>
