# Copy to .env (gitignored) and fill in real creds. No quotes - docker env_file
# takes values literally.
ILO_IP=10.0.0.245
ILO_USER=Administrator
ILO_PASS=changeme
IDRAC_IP=10.0.0.81
IDRAC_USER=root
IDRAC_PASS=changeme

# --- platform auth ---
SESSION_SECRET=generate_with_openssl_rand_hex_32
PLATFORM_USER=admin
PLATFORM_PASS=changeme
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_USERS=your-github-login

# Fan max RPM for the % <-> RPM dashboard toggle (best-guess defaults; tune to taste)
FAN_MAX_ILO=18000
FAN_MAX_IDRAC=12000

# --- reverse proxy / TLS ---
# Set TRUST_PROXY=1 ONLY when the app is reached solely through a TLS proxy
# (Nginx Proxy Manager, etc.) that sets X-Forwarded-Proto. It makes OAuth
# redirects use https and marks the session cookie Secure.
TRUST_PROXY=0
# Host interface the container's 8088 binds to. Default 127.0.0.1 keeps it off
# the LAN (proxy fronts it). Set 0.0.0.0 to reach :8088 directly - not advised.
WEB_BIND=127.0.0.1
