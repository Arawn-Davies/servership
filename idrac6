#!/bin/bash
# Open the iDRAC6 web UI in firefox-esr (its TLS is loosened for the old cert).
# Log in, then Console/Media -> Launch Virtual Console (Java) for the vKVM, which
# opens as its own window on this display. Runs on the display the launch
# listener assigns (:2).
# Usage: idrac6 <idrac-ip> [user] [pass]
IP="${1:?usage: idrac6 <idrac-ip> [user] [pass]}"
export DISPLAY="${DISPLAY:-:2}"
PROFILE=/root/.ffesr-idrac
mkdir -p "$PROFILE"

# Open maximized (fills the display). A fresh profile otherwise starts at a
# small default size, leaving black borders around the window in the noVNC view.
[ -f "$PROFILE/xulstore.json" ] || printf '%s' \
  '{"chrome://browser/content/browser.xul":{"main-window":{"screenX":"0","screenY":"0","width":"1280","height":"1024","sizemode":"maximized"}}}' \
  > "$PROFILE/xulstore.json"

# Pre-seed the iDRAC cert exception so the "connection is not secure" page never
# appears (Firefox-generated override for this iDRAC's default self-signed cert;
# if it ever changes, delete this file and accept once to regenerate).
[ -f "$PROFILE/cert_override.txt" ] || printf \
'# PSM Certificate Override Settings file\n# This is a generated file!  Do not edit.\n%s:443:\tOID.2.16.840.1.101.3.4.2.1\t%s\tMUT\t%s\n' \
  "$IP" \
  'A8:76:20:12:DB:EC:E1:1D:78:F4:CC:AD:3A:71:61:B9:33:89:12:E7:09:DA:67:9B:6E:A1:FA:8C:01:15:50:85' \
  'AAAAAAAAAAAAAAAJAAAAjADWVVR9Izz0fDCBiTELMAkGA1UEBhMCVVMxDjAMBgNVBAgMBVRleGFzMRMwEQYDVQQHDApSb3VuZCBSb2NrMRIwEAYDVQQKDAlEZWxsIEluYy4xHDAaBgNVBAsME1JlbW90ZSBBY2Nlc3MgR3JvdXAxIzAhBgNVBAMMGmlEUkFDNiBkZWZhdWx0IGNlcnRpZmljYXRl' \
  > "$PROFILE/cert_override.txt"

# Kiosk + no session nag + disable DHE (iDRAC's DHE handshake is ~4s vs ~1.5s on
# RSA; force RSA key exchange). Rewritten each launch.
mkdir -p "$PROFILE/chrome"
printf '%s\n' \
  '#nav-bar, #TabsToolbar, #toolbar-menubar, #PersonalToolbar { visibility: collapse !important; }' \
  > "$PROFILE/chrome/userChrome.css"
printf '%s\n' \
  'user_pref("toolkit.legacyUserProfileCustomizations.stylesheets", true);' \
  'user_pref("browser.sessionstore.resume_from_crash", false);' \
  'user_pref("browser.sessionstore.max_resumed_crashes", 0);' \
  'user_pref("toolkit.startup.max_resumed_crashes", -1);' \
  'user_pref("security.ssl3.rsa_aes_128_sha", true);' \
  'user_pref("security.ssl3.rsa_aes_256_sha", true);' \
  'user_pref("security.ssl3.dhe_rsa_aes_128_sha", false);' \
  'user_pref("security.ssl3.dhe_rsa_aes_256_sha", false);' \
  'user_pref("security.ssl3.dhe_rsa_aes_128_gcm_sha256", false);' \
  'user_pref("security.ssl3.dhe_rsa_aes_256_gcm_sha384", false);' \
  > "$PROFILE/user.js"

exec firefox-esr --no-remote --profile "$PROFILE" "https://$IP"
