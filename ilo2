#!/bin/bash
# Open the iLO2 web UI in the loosened Firefox; log in and click
# "Remote Console" -> the Java applet, which hands off to javaws.
# Usage: ilo2 <ilo-ip>
IP="${1:?usage: ilo2 <ilo-ip>}"
export DISPLAY=:1
echo "Opening iLO2 at https://$IP  — log in, then Remote Console > Java."
firefox-esr "https://$IP" &
